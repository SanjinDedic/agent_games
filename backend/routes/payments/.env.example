# Copy this file to `.env` (same folder) and fill in your own Stripe test-mode values.
# `backend/routes/payments/.env` is gitignored and never committed.
#
#   RESTRICTED_KEY         — Stripe dashboard > Developers > API keys (rk_test_...)
#   PUBLISHABLE_KEY        — Stripe dashboard > Developers > API keys (pk_test_...)
#   SECRET_STRIPE_KEY      — Stripe dashboard > Developers > API keys (sk_test_...)
#   STRIPE_WEBHOOK_SECRET  — printed by: stripe listen --forward-to localhost:8000/payments/webhook
#
# Two Prices per tier: a one-time 90-day pass and a yearly recurring
# subscription (the annual Price is higher). The buyer's auto-renew choice
# selects which one Checkout uses.
#   STRIPE_PRICE_CLUB_ONCE — Club 90 Days > one-time price ID (price_...)
#   STRIPE_PRICE_CLUB_YEAR — Club Annual Recurring > yearly price ID (price_...)
#   STRIPE_PRICE_UNI_ONCE  — University 90 Days > one-time price ID (price_...)
#   STRIPE_PRICE_UNI_YEAR  — University Annual Recurring > yearly price ID (price_...)
RESTRICTED_KEY=
PUBLISHABLE_KEY=
SECRET_STRIPE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CLUB_ONCE=
STRIPE_PRICE_CLUB_YEAR=
STRIPE_PRICE_UNI_ONCE=
STRIPE_PRICE_UNI_YEAR=
