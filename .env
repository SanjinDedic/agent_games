# Local dev defaults — safe to commit. Mirrors config/deploy.yml env.secret keys.
# Production overrides: .kamal/secrets (Kamal deploy).
# Local AWS override (real S3): .aws.env (gitignored, loaded after .env by docker-compose).

SECRET_KEY=test_secret_key_for_tests
DATABASE_URL=postgresql+psycopg://postgres:local_pw@postgres:5432/agent_games

# Default login: admin / admin
ADMIN_PASSWORD=admin

# Default login: "Admin Institution" / institution
INSTITUTION_PASSWORD=institution

# Postgres superuser: postgres / local_pw
POSTGRES_PASSWORD=local_pw

# MinIO root creds (used as AWS_* for local S3): minioadmin / minioadmin
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=agent-games-backups
AWS_S3_ASSETS_BUCKET=agent-games-assets


# Hint rationing (dev: generous — hint on every submission, no cooldown).
# Production defaults live in backend/routes/ai/hint_service.py: 300s / 3 submissions.
# The test-runner container does not load .env, so tests keep the prod defaults.
HINT_COOLDOWN_SECONDS=0
SUBMISSIONS_BETWEEN_HINTS=1


# STRIPE — all config (keys + price IDs) lives in backend/routes/payments/.env
# (gitignored). Copy backend/routes/payments/.env.example to get started.